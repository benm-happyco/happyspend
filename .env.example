# Supabase (required for app)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Happy Spend: optional second Supabase project (sourcing_events table).
# If set, Happy Spend uses this project; otherwise it uses the default project above.
VITE_SUPABASE_SPEND_URL=https://your-spend-project.supabase.co
VITE_SUPABASE_SPEND_ANON_KEY=your-spend-anon-key
